      "x": 0,
      "y": 80,
      "width": 180,
      "height": 100
    },
    {
      "id": "user_bloc",
      "type": "text",
      "text": "⚡ UserBloc\n\nLoadUser\nSaveUser\nUpdateUser\nDeleteUser\n\n→ UserRepository\n\n→ [[Lista_Adicoes#bocs]]",
      "x": -250,
      "y": 200,
      "width": 180,
      "height": 100
    },
    {
      "id": "meal_bloc",
      "type": "text",
      "text": "⚡ MealBloc\n\nLoadMeals\nAddMeal / UpdateMeal\nDeleteMeal\nAddFoodToMeal\nRemoveFoodFromMeal\n\n→ SyncMealRepository\n\n→ [[Lista_Adicoes#bocs]]",
      "x": -50,
      "y": 200,
      "width": 200,
      "height": 110
    },
    {
      "id": "water_bloc",
      "type": "text",
      "text": "⚡ WaterBloc\n\nLoadWaterIntake\nAddWater / RemoveWater\nSetWaterGoal\nResetWaterIntake\n\n→ SharedPreferences\n\n→ [[Lista_Adicoes#controle-de-água]]",
      "x": 180,
      "y": 200,
      "width": 180,
      "height": 100
    },
    {
      "id": "food_scanner_bloc",
      "type": "text",
      "text": "⚡ FoodScannerBloc\n\nAnalyzeImage (IA)\nAnalyzeText (IA)\nSearchFoodByName\nSelectFood / DeselectFood\n\n→ AiFoodService\n→ UsdaFoodService\n\n→ [[Lista_Adicoes#scanner-de-código-de-barras]]",
      "x": -350,
      "y": 320,
      "width": 220,
      "height": 110
    },
    {
      "id": "barcode_bloc",
